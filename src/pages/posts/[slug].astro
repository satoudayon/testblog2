---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
	dateStyle: 'long',
});
---

<Layout title={`${post.data.title} | Markdown Blog Starter`} description={post.data.description}>
	<article class="post">
		<p class="post-date">{dateFormatter.format(post.data.pubDate)}</p>
		<h1>{post.data.title}</h1>
		<p class="post-description">{post.data.description}</p>
		<div class="tag-list">
			{post.data.tags.map((tag: string) => <span>{tag}</span>)}
		</div>
		<div class="content">
			<Content />
		</div>
	</article>
</Layout>

<style>
	.post {
		padding: clamp(1.5rem, 4vw, 3rem);
		background: rgba(255, 250, 240, 0.96);
		border: 1px solid rgba(31, 41, 55, 0.1);
		border-radius: 2rem;
		box-shadow: 0 24px 60px rgba(31, 41, 55, 0.08);
	}

	.post-date {
		margin: 0;
		font-size: 0.85rem;
		font-weight: 700;
		color: #9a3412;
	}

	h1 {
		margin: 0.6rem 0 1rem;
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 1.1;
	}

	.post-description {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.8;
		color: #4b5563;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin: 1.2rem 0 2rem;
	}

	.tag-list span {
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		background: #fff7ed;
		border: 1px solid rgba(180, 83, 9, 0.18);
		font-size: 0.85rem;
		color: #9a3412;
	}

	.content :global(*) {
		max-width: 100%;
	}

	.content :global(p),
	.content :global(li) {
		line-height: 1.9;
		color: #1f2937;
	}

	.content :global(h2),
	.content :global(h3) {
		margin-top: 2rem;
		line-height: 1.3;
	}

	.content :global(pre) {
		padding: 1rem;
		border-radius: 1rem;
		overflow-x: auto;
		background: #1f2937;
		color: #f9fafb;
	}

	.content :global(code) {
		font-family: Consolas, monospace;
	}

	.content :global(a) {
		color: #9a3412;
	}
</style>
