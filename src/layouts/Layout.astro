---
interface Props {
	title: string;
	description?: string;
}

const { title, description = 'AstroとMarkdownで管理する学習用ブログです。' } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const homeHref = basePath;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
		<link rel="icon" href={`${basePath}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<div class="app-frame">
				<div class="browser-bar">
					<div class="browser-dots">
						<span class="dot red"></span>
						<span class="dot yellow"></span>
						<span class="dot green"></span>
					</div>
					<div class="browser-search"></div>
					<div class="browser-icons">
						<span></span>
						<span></span>
						<span></span>
					</div>
				</div>

				<header class="site-header">
					<a class="site-brand" href={homeHref}>STREAMLINED</a>
					<nav class="site-nav">
						<a href={homeHref}>HOME</a>
						<a href={homeHref}>ARTICLES</a>
						<a href={homeHref}>GUIDES</a>
						<a href={homeHref}>CATEGORIES</a>
						<a href={homeHref}>ABOUT</a>
					</nav>
					<a class="subscribe-button" href={homeHref}>SUBSCRIBE</a>
				</header>

				<main class="page-content">
					<slot />
				</main>

				<footer class="site-footer">
					<div class="footer-links">
						<a href={homeHref}>Contact</a>
						<a href={homeHref}>Privacy Policy</a>
						<a href={homeHref}>Terms</a>
						<a href={homeHref}>Careers</a>
					</div>
					<p>© 2026 Streamlined Notes</p>
				</footer>
			</div>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #edf3f8;
		--surface: #ffffff;
		--surface-soft: #f8fbfd;
		--text: #111827;
		--muted: #6b7280;
		--line: #d9e5ec;
		--line-strong: #bfd4df;
		--accent: #32b8d6;
		--accent-deep: #179ebd;
		--shadow: 0 36px 90px rgba(43, 64, 84, 0.16);
	}

	* {
		box-sizing: border-box;
	}

	html {
		font-family: "Segoe UI", "Yu Gothic UI", "Hiragino Sans", sans-serif;
		color: var(--text);
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.95), transparent 22rem),
			radial-gradient(circle at left top, rgba(50, 184, 214, 0.12), transparent 18rem),
			radial-gradient(circle at right center, rgba(50, 184, 214, 0.12), transparent 20rem),
			linear-gradient(180deg, #f8fbfe 0%, var(--bg) 100%);
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	a {
		color: inherit;
	}

	.page-shell {
		width: min(1240px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 2rem 0 3rem;
	}

	.app-frame {
		background: rgba(255, 255, 255, 0.88);
		border: 1px solid rgba(191, 212, 223, 0.9);
		border-radius: 26px;
		box-shadow: var(--shadow);
		overflow: hidden;
		backdrop-filter: blur(18px);
	}

	.browser-bar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: 0.95rem 1.5rem;
		border-bottom: 1px solid var(--line);
		background: linear-gradient(180deg, #ffffff, #f7fafc);
	}

	.browser-dots,
	.browser-icons {
		display: flex;
		gap: 0.55rem;
		align-items: center;
	}

	.browser-icons {
		justify-content: end;
	}

	.dot,
	.browser-icons span {
		display: inline-flex;
		width: 0.8rem;
		height: 0.8rem;
		border-radius: 999px;
		border: 1px solid rgba(17, 24, 39, 0.14);
		background: #fff;
	}

	.dot.red {
		background: #ff6f61;
	}

	.dot.yellow {
		background: #ffd166;
	}

	.dot.green {
		background: #7bd88f;
	}

	.browser-search {
		width: min(360px, 100%);
		height: 1.35rem;
		border-radius: 999px;
		background: linear-gradient(180deg, #f2f5f8, #e9eef3);
		justify-self: center;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.2rem;
		padding: 1.15rem 2rem;
		border-bottom: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.92);
	}

	.site-brand {
		font-size: 1.65rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-decoration: none;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		flex: 1;
	}

	.site-nav a {
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-decoration: none;
		color: #4b5563;
	}

	.site-nav a:first-child {
		color: var(--accent-deep);
	}

	.subscribe-button {
		padding: 0.65rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(50, 184, 214, 0.7);
		color: var(--accent-deep);
		font-size: 0.78rem;
		font-weight: 800;
		text-decoration: none;
		letter-spacing: 0.06em;
	}

	.page-content {
		padding: 2rem;
	}

	.site-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1rem 2rem 1.4rem;
		border-top: 1px solid var(--line);
		font-size: 0.78rem;
		color: var(--muted);
	}

	.site-footer p {
		margin: 0;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-links a {
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.browser-bar {
			grid-template-columns: auto 1fr auto;
			gap: 1rem;
		}

		.site-header {
			flex-direction: column;
			align-items: stretch;
			padding: 1rem 1.2rem;
		}

		.page-content,
		.site-footer {
			padding-left: 1.2rem;
			padding-right: 1.2rem;
		}

		.site-nav {
			justify-content: start;
		}

		.subscribe-button {
			align-self: start;
		}
	}

	@media (max-width: 720px) {
		.page-shell {
			width: min(100% - 1.25rem, 1100px);
			padding-top: 1rem;
		}

		.browser-search {
			display: none;
		}

		.browser-bar {
			grid-template-columns: 1fr auto;
		}

		.site-footer {
			flex-direction: column;
			align-items: start;
		}
	}
</style>
